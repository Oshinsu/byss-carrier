# ═══════════════════════════════════════════════════════
# BYSS CARRIER — Environment Variables
# Copy to .env.local and fill in values
# REQUIRED = app won't work without it
# OPTIONAL = feature degrades gracefully
# ═══════════════════════════════════════════════════════

# ── Supabase (REQUIRED) ──────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── AI (REQUIRED — at least one) ─────────────────────
ANTHROPIC_API_KEY=                # Direct Claude calls (Village IA, briefings)
OPENROUTER_API_KEY=               # Multi-model routing via SOTAI V3

# ── AI — Optional ────────────────────────────────────
OPENAI_API_KEY=                   # OPTIONAL: JARVIS Realtime voice mode (WebRTC)

# ── OpenRouter Model Routing (OPTIONAL — defaults exist) ──
OPENROUTER_ANALYSIS_MODEL=
OPENROUTER_HEAVY_MODEL=
OPENROUTER_CODE_HEAVY_MODEL=
OPENROUTER_FACTUAL_MODEL=
OPENROUTER_CODE_MODEL=
OPENROUTER_FINANCE_MODEL=
OPENROUTER_DAILY_MODEL=
OPENROUTER_DEFAULT_MODEL=

# ── AI SDK Model Aliases (OPTIONAL) ──────────────────
AI_MODEL_OPUS=
AI_MODEL_SONNET=
AI_MODEL_GPT=

# ── Email (OPTIONAL — email features disabled without it) ──
RESEND_API_KEY=

# ── Media Generation (OPTIONAL — image/video/music/voice disabled without it) ──
REPLICATE_API_TOKEN=

# ── Payments (OPTIONAL — finance features disabled without it) ──
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=           # OPTIONAL: client-side Stripe elements

# ── Auth (OPTIONAL — Google OAuth) ───────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Monitoring (OPTIONAL) ────────────────────────────
SENTRY_DSN=

# ── GitHub (OPTIONAL — code intelligence features) ───
GITHUB_TOKEN=

# ── Integrations (OPTIONAL) ─────────────────────────
POLYMARKET_API_KEY=

# ── App Configuration ────────────────────────────────
NEXT_PUBLIC_APP_URL=              # OPTIONAL: defaults to localhost:3000
ADMIN_EMAIL=                      # OPTIONAL: admin notification target
ADMIN_SUPABASE_EMAIL=             # OPTIONAL: auth-gated admin email
BYSS_REPO_ROOT=                   # OPTIONAL: local knowledge base path (dev only)
