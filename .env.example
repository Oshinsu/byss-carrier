# ═══════════════════════════════════════════════════════
# BYSS CARRIER — Environment Variables
# Copy to .env.local and fill in values
# ═══════════════════════════════════════════════════════

# ── Supabase (database, auth, storage) ──
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── AI ──
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
OPENAI_API_KEY=              # Optional: enables JARVIS OpenAI Realtime voice mode (WebRTC)

# ── OpenRouter Model Routing ──
OPENROUTER_ANALYSIS_MODEL=
OPENROUTER_HEAVY_MODEL=
OPENROUTER_CODE_HEAVY_MODEL=
OPENROUTER_FACTUAL_MODEL=
OPENROUTER_CODE_MODEL=
OPENROUTER_FINANCE_MODEL=
OPENROUTER_DAILY_MODEL=
OPENROUTER_DEFAULT_MODEL=

# ── AI SDK Model Aliases ──
AI_MODEL_OPUS=
AI_MODEL_SONNET=
AI_MODEL_GPT=

# ── Email (Resend) ──
RESEND_API_KEY=

# ── Media Generation ──
REPLICATE_API_TOKEN=

# ── Payments (Stripe) ──
STRIPE_SECRET_KEY=

# ── GitHub ──
GITHUB_TOKEN=

# ── Integrations (optional) ──
POLYMARKET_API_KEY=
DATAGOUV_API_KEY=
DOCUMENSO_API_KEY=
DOCUMENSO_API_URL=https://app.documenso.com/api/v1
PAPERMARK_API_KEY=
PAPERMARK_API_URL=https://api.papermark.io/api/v1
PAPERCLIP_URL=

# ── App ──
NEXT_PUBLIC_APP_URL=
ADMIN_EMAIL=
ADMIN_SUPABASE_EMAIL=
BYSS_REPO_ROOT=
